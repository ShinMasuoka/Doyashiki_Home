---
import { getEntry } from 'astro:content';
import { Image } from 'astro:assets';
import PageShell from '../components/PageShell.astro';
import PageTitle from '../components/PageTitle.astro';
import ReservationCTA from '../components/ReservationCTA.astro';

import hagamaImg from '../assets/images/experiences/hagama.jpg';

// 実写真があるグループだけここに追加していく
const groupImages: Record<string, ImageMetadata | undefined> = {
  fire: hagamaImg,
};

const data = (await getEntry('amenities', 'ja'))!.data;
---

<PageShell
  title={data.seo.title}
  description={data.seo.description}
  canonicalPath="/amenities/"
>
  <PageTitle label={data.label} heading={data.heading} lead={data.lead} />

  <section class="amenities">
    <div class="am-inner">
      {data.groups.map((group, i) => (
        <article class:list={['am-group', i < data.groups.length - 1 && 'am-group--border']}>
          <h2 class="am-title">{group.title}</h2>
          <p class="am-body">{group.body}</p>
          {group.items && (
            <ul class="am-items">
              {group.items.map((item) => <li class="am-item">{item}</li>)}
            </ul>
          )}
          {groupImages[group.id] && (
            <Image
              src={groupImages[group.id]!}
              alt={group.title}
              width={960}
              class="am-img"
            />
          )}
        </article>
      ))}

      <p class="diy-note">{data.diyNote}</p>
    </div>
  </section>

  <ReservationCTA heading={data.cta.heading} sub={data.cta.sub} />
</PageShell>

<style>
  .amenities {
    background: var(--color-panel);
    padding: 8px var(--px-section-lg) 44px;
  }

  .am-inner {
    max-width: var(--max-width-faq);
    margin: 0 auto;
  }

  .am-group {
    padding: 24px 0;
  }

  .am-group--border {
    border-bottom: 0.5px solid var(--color-border);
  }

  .am-title {
    margin: 0 0 8px;
    font-family: var(--font-mincho);
    font-weight: 600;
    font-size: 17px;
    letter-spacing: var(--tracking-heading-sm);
  }

  .am-title::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 1px;
    background: var(--color-accent);
    margin-right: 10px;
    vertical-align: middle;
  }

  .am-body {
    margin: 0;
    font-size: var(--text-body-sm);
    line-height: var(--leading-exp);
    color: var(--color-text-sub);
  }

  .am-items {
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
  }

  .am-item {
    border: 0.5px solid var(--color-border-pill);
    border-radius: var(--radius-pill);
    padding: 5px 12px;
    font-size: 12px;
    color: var(--color-text-weak);
  }

  .am-img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-image);
    object-fit: cover;
    aspect-ratio: 3 / 2;
    margin-top: 14px;
  }

  .diy-note {
    margin: 28px 0 0;
    padding-left: 12px;
    border-left: 2px solid var(--color-leaf);
    font-family: var(--font-mincho);
    font-size: var(--text-quote);
    line-height: var(--leading-quote);
    color: var(--color-leaf-dark);
  }

  /* ===== PC（768px以上）===== */
  @media (min-width: 768px) {
    .amenities {
      padding: 8px var(--px-section-pc) 72px;
    }

    .am-inner {
      max-width: var(--max-width-text);
    }

    .am-group {
      padding: 32px 0;
    }

    .am-title {
      font-size: 20px;
    }

    .am-body {
      font-size: var(--text-body);
    }

    .diy-note {
      margin-top: 36px;
    }
  }
</style>
