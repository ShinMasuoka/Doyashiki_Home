---
---

<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/summercamp2026/logo_osaji.svg" />
<title>自分を見つける夏合宿 in にしあわくら 2026 | 西粟倉村</title>
<link href="https://fonts.googleapis.com/css2?family=RocknRoll+One&family=Zen+Maru+Gothic:wght@400;500;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--gd:#166534;--gm:#16a34a;--gl:#4ade80;--gp:#dcfce7;--earth:#b5835a;--earth-l:#f2e0cc;--cream:#faf7f2;--td:#1a1a1a;--tm:#4a4a4a;--tl:#888;--w:#ffffff}
html{scroll-behavior:smooth}
body{font-family:"Zen Maru Gothic",sans-serif;background:var(--cream);color:var(--td);line-height:1.7}
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(250,247,242,0.95);backdrop-filter:blur(8px);border-bottom:1px solid rgba(45,106,79,0.15);padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{font-family:"RocknRoll One",sans-serif;font-size:1rem;font-weight:700;color:var(--gd);text-decoration:none;line-height:1.3}
.nav-logo span{display:block;font-size:0.65rem;font-weight:400;color:var(--tl);letter-spacing:0.08em}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{font-size:0.8rem;color:var(--tm);text-decoration:none;letter-spacing:0.05em;transition:color 0.2s}
.nav-links a:hover{color:var(--gm)}
.nav-cta{background:var(--gm) !important;color:var(--w) !important;padding:0.45rem 1.1rem;border-radius:50px;font-size:0.8rem !important}
#hero{padding-top:64px;padding-bottom:0;position:relative;height:100vh;overflow:hidden}
.hero-bg{width:100%;height:100%;background:linear-gradient(160deg,#1a4d35,#0d2b1e);display:flex;align-items:center;justify-content:center;flex-direction:column;color:rgba(255,255,255,0.2);font-size:0.85rem;gap:1rem}
.hero-bg svg{width:56px;height:56px;opacity:0.25}
.hero-bg picture,.hero-bg img{display:block;width:100%;height:100%;object-fit:cover;object-position:center}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,0) 0%,rgba(0,0,0,0) 40%,rgba(0,0,0,0.45) 100%)}
.hero-text{position:absolute;bottom:0;left:0;right:0;padding:4rem 5rem;color:var(--w)}
.hero-badge{display:inline-block;background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);font-size:0.72rem;font-weight:700;letter-spacing:0.12em;padding:0.35rem 0.9rem;border-radius:50px;margin-bottom:1.5rem}
.hero-title{font-family:"RocknRoll One",sans-serif;font-size:3.2rem;font-weight:700;line-height:1.5;margin-bottom:1.5rem}
.hero-title em{font-style:normal}
.hero-meta-row{display:flex;gap:2rem;margin-bottom:2rem;flex-wrap:wrap}
.hero-meta-item{display:flex;align-items:center;gap:0.5rem;font-size:0.9rem;opacity:0.9}
.hero-meta-item svg{width:16px;height:16px;flex-shrink:0}
.hero-buttons{display:flex;gap:1rem}
.btn-primary{background:var(--gl);color:var(--w);padding:0.9rem 2.2rem;border-radius:50px;font-size:0.95rem;font-weight:700;text-decoration:none;transition:background 0.2s,transform 0.15s;display:inline-flex;align-items:center;gap:0.5rem}
.btn-primary:hover{background:var(--gm);transform:translateY(-1px)}
.hero-seats{position:absolute;top:calc(64px + 2rem);right:2rem;background:rgba(255,255,255,0.12);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,0.2);border-radius:12px;padding:1.2rem 1.5rem;color:white;text-align:center}
.seats-label{font-size:0.72rem;opacity:0.7;letter-spacing:0.06em;margin-bottom:0.3rem}
.seats-num{font-family:"RocknRoll One",sans-serif;font-size:2.2rem;font-weight:700;line-height:1}
.seats-sub{font-size:0.78rem;opacity:0.8}
.scroll-indicator{position:absolute;bottom:1.6rem;left:50%;display:flex;flex-direction:column;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.85);font-size:0.7rem;font-weight:700;letter-spacing:0.2em;animation:scroll-bounce 2.2s ease-in-out infinite}
.scroll-indicator svg{width:18px;height:18px}
@keyframes scroll-bounce{0%,100%{transform:translate(-50%,0)}50%{transform:translate(-50%,10px)}}
.photo-band{display:grid;grid-template-columns:2fr 1fr 1fr;height:340px;gap:3px}
.photo-band-item{overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.5rem;font-size:0.75rem}
.photo-band-item svg{opacity:0.5}
.photo-band-item .ph-label{position:absolute;bottom:0.7rem;left:0.7rem;background:rgba(255,255,255,0.9);color:var(--gd);font-size:0.72rem;font-weight:700;padding:0.2rem 0.7rem;border-radius:50px}
.photo-band-item img{width:100%;height:100%;object-fit:cover}
section{padding:6rem 0}
.container{max-width:1080px;margin:0 auto;padding:0 2rem}
.section-title{font-family:"RocknRoll One",sans-serif;font-size:2rem;font-weight:700;color:var(--gd);line-height:1.5;margin-bottom:3rem}
#worries{background:var(--w)}
.worries-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:1.2rem}
.worry-card{background:var(--cream);border:1.5px solid rgba(45,106,79,0.12);border-radius:12px;padding:1.5rem;display:flex;align-items:flex-start;gap:0.8rem;transition:border-color 0.2s,transform 0.15s}
.worry-card:hover{border-color:var(--gl);transform:translateY(-2px)}
.worry-check{width:22px;height:22px;border-radius:50%;background:var(--gp);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.worry-check svg{width:12px;height:12px;color:var(--gm)}
.worry-text{font-size:0.9rem;color:var(--tm);line-height:1.6}
#why{background:var(--cream)}
.why-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem}
.why-card{background:var(--w);border-radius:16px;overflow:hidden;border:1px solid rgba(45,106,79,0.1);transition:transform 0.2s,box-shadow 0.2s}
.why-card:hover{transform:translateY(-3px);box-shadow:0 8px 32px rgba(45,106,79,0.1)}
.why-card-photo{position:relative;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.5rem;font-size:0.75rem;min-height:120px}
.why-card-photo img{width:100%;height:auto;display:block}
.why-card-photo svg{opacity:0.5}
.why-card-photo .photo-tag{position:absolute;top:0.8rem;left:0.8rem;background:var(--gm);color:var(--w);font-size:0.7rem;font-weight:700;padding:0.2rem 0.7rem;border-radius:50px}
.why-card-body{padding:1.5rem}
.why-card-body h3{font-family:"RocknRoll One",sans-serif;font-size:1.1rem;color:var(--gd);margin-bottom:0.5rem;display:flex;align-items:center;gap:0.5rem}
.why-card-body p{font-size:0.88rem;color:var(--tm);line-height:1.7}
#days{background:var(--gd);color:var(--w)}
#days .section-title{color:var(--w)}
.days-tabs{display:flex;gap:0;margin-bottom:3rem;border:1.5px solid rgba(255,255,255,0.2);border-radius:50px;padding:4px;width:fit-content}
.day-tab{padding:0.6rem 1.8rem;border-radius:50px;font-size:0.85rem;font-weight:700;cursor:pointer;transition:all 0.2s;color:rgba(255,255,255,0.6);border:none;background:transparent}
.day-tab.active{background:var(--gl);color:var(--w)}
.day-content{display:none}
.day-content.active{display:block}
.day-layout{display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start}
.day-photos{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.day-photo-main{grid-column:1/-1;aspect-ratio:16/9;background:rgba(255,255,255,0.1);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.5rem;color:rgba(255,255,255,0.3);font-size:0.78rem;border:1.5px dashed rgba(255,255,255,0.15);overflow:hidden}
.day-photo-main img{width:100%;height:100%;object-fit:cover}
.day-photo-main svg{width:32px;height:32px}
.day-photo-sub{aspect-ratio:4/3;background:rgba(255,255,255,0.07);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.4rem;color:rgba(255,255,255,0.25);font-size:0.72rem;border:1.5px dashed rgba(255,255,255,0.1);overflow:hidden}
.day-photo-sub img{width:100%;height:100%;object-fit:cover}
.day-photo-sub svg{width:24px;height:24px}
.day-img-full{display:block;width:100%;border-radius:16px}
.day-theme{display:inline-flex;align-items:center;gap:0.5rem;background:rgba(82,183,136,0.2);color:var(--gl);font-size:0.75rem;font-weight:700;letter-spacing:0.1em;padding:0.35rem 0.9rem;border-radius:50px;margin-bottom:1.2rem}
.day-title{font-family:"RocknRoll One",sans-serif;font-size:1.8rem;color:var(--w);margin-bottom:1rem;line-height:1.4}
.day-desc{font-size:0.9rem;color:rgba(255,255,255,0.75);line-height:1.8;margin-bottom:1.5rem}
.day-activities{display:flex;flex-wrap:wrap;gap:0.5rem}
.activity-tag{background:rgba(255,255,255,0.1);color:rgba(255,255,255,0.85);font-size:0.78rem;padding:0.3rem 0.8rem;border-radius:50px}
#gallery{background:var(--w);padding:0}
.gallery-header{padding:6rem 2rem 3rem;max-width:1080px;margin:0 auto}
.gallery-mosaic{display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.g-item{overflow:hidden;position:relative;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.5rem;transition:transform 0.3s}
.g-item:hover{transform:scale(1.02);z-index:1}
.g-item img{width:100%;height:100%;object-fit:cover}
.g-item svg{opacity:0.45}
.g-item .g-label{position:absolute;bottom:0.8rem;left:0.8rem;background:rgba(255,255,255,0.92);color:var(--gd);font-size:0.72rem;font-weight:700;padding:0.25rem 0.7rem;border-radius:50px}
.g-item .g-num{position:absolute;top:0.8rem;right:0.8rem;background:rgba(255,255,255,0.7);color:var(--tm);font-size:0.65rem;padding:0.15rem 0.5rem;border-radius:50px}
.g-std{height:220px}
.g-tall{height:444px;grid-row:span 2}
.g-wide{height:220px;grid-column:span 2}
.gallery-note{text-align:center;padding:1.5rem 2rem 3rem;font-size:0.82rem;color:var(--tl)}
.sue-photo{margin-top:1.5rem;width:100%;border-radius:16px;display:block;object-fit:cover}
@media(min-width:769px){.sue-photo{width:50%}}
.scene-strip{background:var(--gd);padding:4rem 0;overflow:hidden}
.scene-strip-title{text-align:center;font-family:"RocknRoll One",sans-serif;font-size:0.88rem;color:rgba(255,255,255,0.4);letter-spacing:0.25em;margin-bottom:2rem}
.scene-scroll{display:flex;gap:8px;padding:0 2rem;overflow-x:auto;scrollbar-width:none}
.scene-scroll::-webkit-scrollbar{display:none}
.scene-item{flex:0 0 280px;height:188px;border-radius:10px;overflow:hidden;background:rgba(255,255,255,0.07);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.4rem;color:rgba(255,255,255,0.25);font-size:0.72rem;border:1.5px dashed rgba(255,255,255,0.1)}
.scene-item img{width:100%;height:100%;object-fit:cover}
.scene-item svg{width:22px;height:22px}
#growth{background:var(--cream)}
.growth-with-photo{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.growth-photo{aspect-ratio:3/4;background:var(--gp);border-radius:16px;overflow:hidden;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.5rem;color:var(--gm);font-size:0.75rem}
.growth-photo img{width:100%;height:100%;object-fit:cover}
.growth-photo svg{opacity:0.45}
.growth-flow{display:flex;flex-direction:column;gap:0}
.growth-step{background:var(--w);border:1.5px solid rgba(45,106,79,0.15);border-radius:14px;padding:1.5rem 2rem;transition:border-color 0.2s,transform 0.15s}
.growth-step:hover{border-color:var(--gl);transform:translateX(4px)}
.growth-step-num{font-size:0.72rem;font-weight:700;letter-spacing:0.1em;color:var(--gm);margin-bottom:0.4rem}
.growth-step-title{font-family:"RocknRoll One",sans-serif;font-size:1.2rem;color:var(--gd)}
.growth-arrow{font-size:1.5rem;color:var(--gl);padding:0.5rem 0;text-align:center}
.growth-result{background:var(--gm);color:var(--w);border-radius:14px;padding:1.8rem 2rem;text-align:center}
.growth-result-label{font-size:0.78rem;opacity:0.8;margin-bottom:0.4rem}
.growth-result-title{font-family:"RocknRoll One",sans-serif;font-size:1.4rem}
#testimonials{background:var(--w)}
.testimonials-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem}
.testimonial-card{background:var(--cream);border-radius:16px;padding:2rem;border:1px solid rgba(45,106,79,0.1)}
.testimonial-stars{color:var(--earth);font-size:1rem;margin-bottom:1rem;letter-spacing:0.1em}
.testimonial-text{font-size:0.95rem;color:var(--td);line-height:1.8;margin-bottom:1.2rem;font-style:italic}
.testimonial-author{display:flex;align-items:center;gap:0.7rem}
.testimonial-avatar{width:38px;height:38px;border-radius:50%;background:var(--gp);display:flex;align-items:center;justify-content:center;font-size:0.8rem;font-weight:700;color:var(--gm);overflow:hidden;flex-shrink:0}
.testimonial-avatar img{width:100%;height:100%;object-fit:cover}
.testimonial-name{font-size:0.85rem;font-weight:700;color:var(--td)}
.testimonial-role{font-size:0.75rem;color:var(--tl)}
#staff{background:var(--cream)}
.staff-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem}
.staff-card{background:var(--w);border-radius:16px;overflow:hidden;border:1px solid rgba(45,106,79,0.1)}
.staff-photo{background:var(--gp);position:relative;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.5rem;color:var(--gm);font-size:0.75rem}
.staff-photo img{width:100%;height:auto;display:block}
.staff-photo svg{opacity:0.4}
.staff-body{padding:1.5rem}
.staff-name{font-family:"RocknRoll One",sans-serif;font-size:1.15rem;color:var(--gd);margin-bottom:0.2rem}
.staff-role{font-size:0.78rem;color:var(--tl);margin-bottom:0.8rem}
.staff-desc{font-size:0.85rem;color:var(--tm);line-height:1.7;margin-bottom:0.8rem}
.staff-tags{display:flex;flex-wrap:wrap;gap:0.4rem}
.staff-tag{background:var(--gp);color:var(--gd);font-size:0.72rem;padding:0.2rem 0.7rem;border-radius:50px}
#safety{background:var(--gd);color:var(--w)}
.safety-with-photo{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center}
.safety-photo{aspect-ratio:4/3;background:rgba(255,255,255,0.08);border-radius:16px;overflow:hidden;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:0.5rem;color:rgba(255,255,255,0.3);font-size:0.75rem;border:1.5px dashed rgba(255,255,255,0.15)}
.safety-photo img{width:100%;height:100%;object-fit:cover}
.safety-photo svg{opacity:0.4}
.safety-list{display:flex;flex-direction:column;gap:1rem}
.safety-item{background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.1);border-radius:12px;padding:1.5rem;display:flex;gap:1rem;align-items:flex-start}
.safety-check{width:28px;height:28px;border-radius:50%;background:var(--gl);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.safety-check svg{width:14px;height:14px;color:white}
.safety-label{font-weight:700;font-size:0.95rem;margin-bottom:0.3rem;color:var(--w)}
.safety-desc{font-size:0.82rem;color:rgba(255,255,255,0.65);line-height:1.6}
#overview{background:var(--w)}
.overview-table{width:100%;border-collapse:collapse;font-size:0.92rem}
.overview-table tr{border-bottom:1px solid rgba(45,106,79,0.1)}
.overview-table tr:last-child{border-bottom:none}
.overview-table th{width:180px;padding:1.2rem 1rem 1.2rem 0;font-weight:700;color:var(--gd);text-align:left;vertical-align:top}
.overview-table td{padding:1.2rem 0;color:var(--tm);line-height:1.7}
.price-tbd{display:inline-block;background:var(--earth-l);color:var(--earth);font-size:0.78rem;font-weight:700;padding:0.25rem 0.8rem;border-radius:50px}
#faq{background:var(--cream)}
.faq-list{display:flex;flex-direction:column;gap:1rem}
.faq-item{background:var(--w);border-radius:12px;border:1px solid rgba(45,106,79,0.1);overflow:hidden}
.faq-question{padding:1.3rem 1.5rem;font-weight:700;color:var(--gd);cursor:pointer;display:flex;justify-content:space-between;align-items:center;font-size:0.95rem;user-select:none}
.faq-question svg{width:20px;height:20px;color:var(--gm);transition:transform 0.2s;flex-shrink:0}
.faq-item.open .faq-question svg{transform:rotate(180deg)}
.faq-answer{display:none;padding:0 1.5rem 1.3rem;font-size:0.9rem;color:var(--tm);line-height:1.8}
.faq-item.open .faq-answer{display:block}
#cta{background:var(--gm);text-align:center;padding:8rem 2rem;position:relative;overflow:hidden}
.cta-bg-photo{position:absolute;inset:0;background:linear-gradient(160deg,#1e5c3e,#0d2b1e);display:flex;align-items:center;justify-content:center;color:rgba(255,255,255,0.1);font-size:0.8rem}
.cta-bg-photo img{width:100%;height:100%;object-fit:cover}
.cta-overlay{position:absolute;inset:0;background:rgba(26,61,43,0.75)}
.cta-content{position:relative;z-index:1}
.cta-eyebrow{font-size:0.72rem;font-weight:700;letter-spacing:0.18em;color:rgba(255,255,255,0.6);text-transform:uppercase;margin-bottom:1rem}
.cta-title{font-family:"RocknRoll One",sans-serif;font-size:2.4rem;font-weight:700;color:var(--w);line-height:1.6;margin-bottom:1rem}
.cta-sub{font-size:1rem;color:rgba(255,255,255,0.8);margin-bottom:0.8rem}
.cta-seats{display:inline-block;background:rgba(255,255,255,0.15);color:var(--w);font-size:0.88rem;font-weight:700;padding:0.4rem 1.2rem;border-radius:50px;margin-bottom:2.5rem;border:1.5px solid rgba(255,255,255,0.3)}
.cta-btn{display:inline-flex;align-items:center;gap:0.5rem;background:var(--w);color:var(--gm);font-weight:700;font-size:1rem;padding:1rem 2.5rem;border-radius:50px;text-decoration:none;transition:all 0.2s}
.cta-btn:hover{background:var(--cream);transform:translateY(-2px)}
footer{background:var(--gd);color:rgba(255,255,255,0.5);text-align:center;padding:2rem;font-size:0.78rem}
.fade-in{opacity:0;transform:translateY(24px);transition:opacity 0.6s ease,transform 0.6s ease}
.fade-in.visible{opacity:1;transform:translateY(0)}
.title-icon{display:inline-block;vertical-align:middle;margin-right:0.5rem;position:relative;top:-3px}
#why,#growth,#days,#testimonials,#worries,#participant-voices,#staff,#safety,#overview,#faq{position:relative;overflow:hidden}
.deco-bg{position:absolute;pointer-events:none;z-index:0}
#why .container,#growth .container,#days .container,#testimonials .container,#worries .container,#participant-voices .container,#staff .container,#safety .container,#overview .container,#faq .container{position:relative;z-index:1}
.curve-sep{display:block;overflow:hidden;line-height:0;font-size:0;margin:0;padding:0}
.curve-sep svg{display:block;width:100%;height:64px}
@media(max-width:768px){.curve-sep svg{height:36px}}
@media(max-width:768px){img.deco-bg{width:150px!important;height:150px!important}}
.nav-hamburger{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px;z-index:101}
.nav-hamburger span{display:block;width:24px;height:2px;background:var(--gd);border-radius:2px;transition:all 0.3s}
.nav-hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nav-hamburger.open span:nth-child(2){opacity:0}
.nav-hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.nav-mobile{display:none;position:fixed;top:64px;left:0;right:0;background:rgba(250,247,242,0.98);backdrop-filter:blur(8px);border-bottom:1px solid rgba(45,106,79,0.15);padding:0.5rem 1.5rem 1.2rem;z-index:99;flex-direction:column}
.nav-mobile.open{display:flex}
.nav-mobile a{display:block;padding:0.85rem 0;font-size:0.95rem;color:var(--tm);text-decoration:none;border-bottom:1px solid rgba(45,106,79,0.08);letter-spacing:0.03em}
.nav-mobile .nav-cta{background:var(--gm)!important;color:var(--w)!important;text-align:center;border-radius:50px;margin-top:0.8rem;border-bottom:none!important;padding:0.75rem;font-weight:700}
@media(max-width:1024px){
  .hero-text{padding:3rem 3rem}
  .hero-title{font-size:2.6rem}
  .day-layout{gap:2rem}
  .gallery-mosaic{grid-template-columns:repeat(3,1fr)}
