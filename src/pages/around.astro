---
import { getEntry } from 'astro:content';
import PageShell from '../components/PageShell.astro';
import PageTitle from '../components/PageTitle.astro';
import ReservationCTA from '../components/ReservationCTA.astro';

const data = (await getEntry('around', 'ja'))!.data;
---

<PageShell
  title={data.seo.title}
  description={data.seo.description}
  canonicalPath="/around/"
>
  <PageTitle label={data.label} heading={data.heading} lead={data.lead} />

  <!-- ===== 地図 ===== -->
  <section class="around-map">
    <div class="map-wrap">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d6521.8092188944165!2d134.335937!3d35.18393!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3555a7e30fc65d57%3A0x7bacfd2d26350731!2z5aCC5bGL5pW3IOmnkOi7iuWgtA!5e0!3m2!1sja!2sus!4v1782795740401!5m2!1sja!2sus"
        class="map-iframe"
        loading="lazy"
        allowfullscreen
        referrerpolicy="strict-origin-when-cross-origin"
        title="堂屋敷駐車場 地図"
      ></iframe>
      <a
        href={data.map.link}
        target="_blank"
        rel="noopener noreferrer"
        class="map-open-link"
      >
        {data.map.openLabel}
      </a>
    </div>
    <p class="map-note">{data.map.note}</p>
  </section>

  <!-- ===== カテゴリー別スポット ===== -->
  <section class="around-list">
    {data.categories.map((category) => (
      <div class="cat">
        <h2 class="cat-title">{category.title}</h2>
        <div class="spot-list">
          {category.spots.map((spot) => (
            <div class="spot">
              <div class="spot-head">
                <span class="spot-name">{spot.name}</span>
                {spot.time && <span class="spot-time">{spot.time}</span>}
              </div>
              <p class="spot-body">{spot.body}</p>
            </div>
          ))}
        </div>
        {category.note && <p class="cat-note">{category.note}</p>}
      </div>
    ))}
  </section>

  <ReservationCTA heading={data.cta.heading} sub={data.cta.sub} />
</PageShell>

<style>
  /* ===== 地図 ===== */
  .around-map {
    background: var(--color-bg);
    padding: 4px var(--px-section-lg) 8px;
  }

  .map-wrap {
    border-radius: var(--radius-image);
    overflow: hidden;
    border: 0.5px solid var(--color-border-strong);
  }

  .map-iframe {
    display: block;
    width: 100%;
    height: 220px;
    border: none;
  }

  .map-open-link {
    display: block;
    background: var(--color-panel-map);
    text-align: center;
    padding: 10px;
    font-size: 12px;
    color: #6F7D4A;
    text-decoration: none;
    letter-spacing: 0.03em;
    border-top: 0.5px solid var(--color-border);
  }

  .map-open-link:hover {
    text-decoration: underline;
  }

  .map-note {
    margin: 10px 2px 0;
    font-size: var(--text-meta);
    color: var(--color-text-muted);
  }

  /* ===== カテゴリー別スポット ===== */
  .around-list {
    background: var(--color-panel);
    margin-top: 24px;
    padding: 8px var(--px-section-lg) 44px;
  }

  .cat {
    padding: 26px 0;
  }

  .cat + .cat {
    border-top: 0.5px solid var(--color-border);
  }

  .cat-title {
    margin: 0 0 16px;
    font-family: var(--font-mincho);
    font-weight: 600;
    font-size: 17px;
    letter-spacing: var(--tracking-heading-sm);
  }

  .cat-title::before {
    content: '';
    display: inline-block;
    width: 14px;
    height: 1px;
    background: var(--color-accent);
    margin-right: 10px;
    vertical-align: middle;
  }

  .spot-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .spot-head {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .spot-name {
    font-weight: 600;
    font-size: var(--text-body-sm);
  }

  .spot-time {
    border: 0.5px solid var(--color-border-pill);
    border-radius: var(--radius-pill);
    padding: 2px 9px;
    font-size: 11px;
    color: var(--color-accent);
    letter-spacing: 0.03em;
  }

  .spot-body {
    margin: 5px 0 0;
    font-size: var(--text-body-xs);
    line-height: var(--leading-exp);
    color: var(--color-text-sub);
  }

  .cat-note {
    margin: 16px 0 0;
    padding-left: 12px;
    border-left: 2px solid var(--color-leaf);
    font-family: var(--font-mincho);
    font-size: var(--text-quote);
    line-height: var(--leading-quote);
    color: var(--color-leaf-dark);
  }

  /* ===== PC（768px以上）===== */
  @media (min-width: 768px) {
    .around-map {
      padding: 4px var(--px-section-pc) 8px;
    }

    .map-wrap,
    .map-note {
      max-width: var(--max-width-access);
      margin-left: auto;
      margin-right: auto;
    }

    .map-iframe {
      height: 380px;
    }

    .around-list {
      padding: 16px var(--px-section-pc) 72px;
    }

    .cat {
      max-width: var(--max-width-access);
      margin: 0 auto;
      padding: 36px 0;
    }

    .cat-title {
      font-size: 20px;
    }

    .spot-list {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 40px;
    }

    .spot-body {
      font-size: var(--text-body-sm);
    }
  }
</style>
