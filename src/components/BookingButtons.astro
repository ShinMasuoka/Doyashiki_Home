---
import { BOOKING_URLS, BOOKING_LABELS_JA, BOOKING_LABELS_EN } from '../config/booking';

interface Props {
  locale: 'ja' | 'en';
  primaryKey?: keyof typeof BOOKING_URLS;
}

const { locale, primaryKey } = Astro.props;
const labels = locale === 'ja' ? BOOKING_LABELS_JA : BOOKING_LABELS_EN;

const primary = locale === 'ja' ? 'official' : (primaryKey ?? 'official');
const primaryUrl = BOOKING_URLS[primary];
const primaryUnderMaintenance = !primaryUrl;

const secondary = (Object.keys(BOOKING_URLS) as Array<keyof typeof BOOKING_URLS>).filter(
  (k) => k !== primary && !!BOOKING_URLS[k]
);

const secondaryLabels: Record<keyof typeof BOOKING_URLS, string> = {
  official: locale === 'ja' ? '公式予約' : 'Official',
  airbnb: labels.airbnb,
  jalan: labels.jalan,
  tabilmo: labels.tabilmo,
};
---

<div class="booking-wrapper">
  {primaryUnderMaintenance ? (
    <div class="btn-maintenance">
      <span class="maintenance-icon">🔧</span>
      <span>
        <span class="maintenance-title">公式予約ページ 整備中</span>
        <span class="maintenance-sub">まもなくご利用いただけます</span>
      </span>
    </div>
  ) : (
    <a href={primaryUrl} class="btn-primary" target="_blank" rel="noopener noreferrer">
      <span class="btn-arrow">▶</span>{labels.primaryLabel ?? labels.officialBtn}
    </a>
  )}
  <p class="others-label">{labels.othersLabel}</p>
  <div class="pill-row">
    {secondary.map((key) => (
      <a href={BOOKING_URLS[key]} class="pill" target="_blank" rel="noopener noreferrer">
        {secondaryLabels[key]}
      </a>
    ))}
  </div>
</div>

<style>
  .booking-wrapper {
    display: flex;
    flex-direction: column;
    align-items: stretch;
  }

  .btn-primary {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    background: var(--color-accent);
    color: #FFFDF7;
    text-decoration: none;
    padding: 18px 22px;
    border-radius: var(--radius-card);
    font-size: 15.5px;
    font-weight: 600;
    letter-spacing: 0.03em;
    box-shadow: var(--shadow-btn);
    transition: opacity 0.15s;
  }

  .btn-primary:hover {
    opacity: 0.9;
  }

  .btn-arrow {
    font-size: 12px;
  }

  .btn-maintenance {
    display: flex;
    align-items: center;
    gap: 12px;
    background: rgba(47, 42, 34, 0.06);
    border: 1px dashed rgba(47, 42, 34, 0.2);
    border-radius: var(--radius-card);
    padding: 16px 20px;
    color: var(--color-text-weak);
  }

  .maintenance-icon {
    font-size: 20px;
    flex-shrink: 0;
  }

  .maintenance-title {
    display: block;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-text-sub);
  }

  .maintenance-sub {
    display: block;
    font-size: 11.5px;
    margin-top: 3px;
    color: var(--color-text-muted);
  }

  .others-label {
    margin: 20px 0 10px;
    font-size: 12px;
    color: var(--color-text-muted2);
    text-align: center;
  }

  .pill-row {
    display: flex;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  .pill {
    text-decoration: none;
    color: var(--color-text-sub);
    border: 0.5px solid var(--color-border-pill);
    border-radius: var(--radius-pill);
    padding: 8px 16px;
    font-size: 13px;
    transition: background 0.15s;
  }

  .pill:hover {
    background: rgba(47, 42, 34, 0.05);
  }

  /* PC：ボタン群が横に伸びすぎないよう幅を制限 */
  @media (min-width: 768px) {
    .booking-wrapper {
      max-width: var(--max-width-booking);
      margin: 0 auto;
    }
  }
</style>
