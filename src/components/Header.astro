---
interface Props {
  locale: 'ja' | 'en';
  siteName: string;
  /** ロゴのリンク先。トップページ以外では "/" を渡す */
  homeHref?: string;
}

const { locale, siteName, homeHref = '#top' } = Astro.props;
const altLocale = locale === 'ja' ? 'en' : 'ja';
// 日本語はルート直下（無接頭辞）、英語は /en/ 配下
const altHref = altLocale === 'ja' ? '/' : `/${altLocale}/`;
const langPillText = locale === 'ja' ? '日本語' : 'EN';
const langAltText = locale === 'ja' ? 'EN' : '日本語';
---

<header id="site-header">
  <a href={homeHref} class="logo-link">{siteName}</a>
  <div class="header-right">
    <a href={altHref} class="lang-pill" aria-label={`Switch to ${altLocale}`}>
      <span class="lang-current">{langPillText}</span>
      <span class="lang-sep"> ｜ </span>
      <span class="lang-alt">{langAltText}</span>
    </a>
    <button id="menu-btn" class="hamburger" aria-label="メニューを開く" aria-expanded="false" aria-controls="menu-overlay">
      <span></span>
      <span></span>
      <span class="short"></span>
    </button>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 40;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 13px 18px;
    background: rgba(255, 253, 247, 0.9);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 0.5px solid var(--color-border-header);
  }

  .logo-link {
    text-decoration: none;
    color: var(--color-text);
    font-family: var(--font-mincho);
    font-size: var(--text-logo);
    font-weight: 600;
    letter-spacing: var(--tracking-logo);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .lang-pill {
    display: inline-flex;
    align-items: center;
    border: 0.5px solid #D8CDB4;
    border-radius: 20px;
    padding: 4px 11px;
    font-size: 12px;
    color: var(--color-text);
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .lang-alt {
    color: #B3A98F;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 2px;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--color-text);
    transition: opacity 0.2s;
  }

  .hamburger span.short {
    width: 16px;
  }

  /* PC：内容を中央の --max-width-wide 幅に収める */
  @media (min-width: 768px) {
    header {
      padding: 16px max(32px, (100% - var(--max-width-wide)) / 2);
    }
  }
</style>
